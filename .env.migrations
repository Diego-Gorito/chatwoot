# Add this to your .env file to enable automatic migrations
# WARNING: Only enable in controlled environments where you trust the migrations

# Enable automatic database migrations on container start
ENABLE_AUTO_MIGRATE=true

# OR, if you prefer to run migrations manually:
# 1. SSH into the server
# 2. Run: docker exec -it chatwoot_rails_1 bundle exec rails db:migrate RAILS_ENV=production
# 3. Or: docker-compose run --rm rails bundle exec rails db:migrate