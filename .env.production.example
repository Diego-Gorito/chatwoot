# ==================================
# DATABASE MIGRATION & BACKUP CONFIG
# ==================================

# Enable automatic database migrations on container start
# This will check for pending migrations and run them automatically
ENABLE_AUTO_MIGRATE=true

# Enable automatic database backup (even without migrations)
# Set to true if you want daily backups on container restart
ENABLE_AUTO_BACKUP=true

# Directory where backups will be stored (inside container)
# This should be a persistent volume to survive container restarts
BACKUP_DIR=/app/storage/backups

# Number of backup files to keep (older ones are deleted)
# Default: 7 (one week of daily backups)
BACKUP_RETENTION=7

# Run database seeds on first setup (only if database is empty)
# Default: false
RUN_DB_SEED=false

# ==================================
# EXISTING CHATWOOT CONFIGURATION
# ==================================

# Add your existing Chatwoot environment variables below...
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432
# POSTGRES_DATABASE=chatwoot_production
# POSTGRES_USERNAME=postgres
# POSTGRES_PASSWORD=your_secure_password
# REDIS_URL=redis://redis:6379
# etc...