# ============================================
# EasyPanel Production Environment Variables
# ============================================
# Copy estas variáveis para o EasyPanel Service → Environment Variables

# ============================================
# 🔐 SECURITY (REQUIRED)
# ============================================

# Generate with: openssl rand -hex 64
SECRET_KEY_BASE=CHANGE_ME_TO_64_CHARACTER_HEX_STRING

# Active Record Encryption (for MFA/2FA)
# Generate with: bundle exec rails db:encryption:init
# ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=
# ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=
# ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=

# ============================================
# 🌐 DOMAIN & URLs (REQUIRED)
# ============================================

# Seu domínio configurado no EasyPanel
FRONTEND_URL=https://seu-dominio.com
# HELPCENTER_URL=https://seu-dominio.com

# ============================================
# 💾 DATABASE (REQUIRED)
# ============================================

# Use as credenciais do PostgreSQL do EasyPanel
# Formato: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres:PASSWORD@postgres:5432/chatwoot

# OU configure individualmente:
# POSTGRES_HOST=postgres
# POSTGRES_USERNAME=postgres
# POSTGRES_PASSWORD=your_password
# POSTGRES_DATABASE=chatwoot

# ============================================
# 📦 REDIS (REQUIRED)
# ============================================

# Use o Redis do EasyPanel
REDIS_URL=redis://redis:6379

# Se Redis tiver senha:
# REDIS_PASSWORD=your_redis_password

# ============================================
# 🚀 RAILS & NODE (REQUIRED)
# ============================================

RAILS_ENV=production
NODE_ENV=production
INSTALLATION_ENV=docker
RAILS_LOG_TO_STDOUT=true
RAILS_SERVE_STATIC_FILES=true
RAILS_MAX_THREADS=5

# ============================================
# 📧 EMAIL (OPTIONAL - mas recomendado)
# ============================================

# SMTP Configuration
MAILER_SENDER_EMAIL=Chatwoot <noreply@seu-dominio.com>
SMTP_DOMAIN=seu-dominio.com
SMTP_ADDRESS=smtp.sendgrid.net  # ou seu provedor SMTP
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=SG.xxxxx  # API key do SendGrid ou senha SMTP
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS_AUTO=true
SMTP_OPENSSL_VERIFY_MODE=peer

# Inbound Email (Reply emails)
# MAILER_INBOUND_EMAIL_DOMAIN=seu-dominio.com

# ============================================
# 🔒 SSL & SECURITY
# ============================================

FORCE_SSL=true

# ============================================
# 👥 SIGNUP CONTROL
# ============================================

# Controla novos cadastros
# true = permite cadastros públicos
# false = desabilita cadastros
# api_only = apenas via API
ENABLE_ACCOUNT_SIGNUP=false

# ============================================
# 📁 STORAGE (OPTIONAL)
# ============================================

# Local Storage (default - usa volume /app/storage)
# ACTIVE_STORAGE_SERVICE=local

# S3 Compatible Storage (recomendado para produção)
# ACTIVE_STORAGE_SERVICE=amazon
# S3_BUCKET_NAME=chatwoot-bucket
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# AWS_REGION=us-east-1
# S3_ENDPOINT=https://s3.amazonaws.com  # ou seu endpoint S3-compatible

# ============================================
# 🤖 INTEGRATIONS (OPTIONAL)
# ============================================

# Facebook
# FB_VERIFY_TOKEN=your_fb_verify_token
# FB_APP_SECRET=your_fb_app_secret
# FB_APP_ID=your_fb_app_id

# Twitter
# TWITTER_APP_ID=your_twitter_app_id
# TWITTER_CONSUMER_KEY=your_twitter_consumer_key
# TWITTER_CONSUMER_SECRET=your_twitter_consumer_secret
# TWITTER_ENVIRONMENT=your_twitter_environment

# Slack
# SLACK_CLIENT_ID=your_slack_client_id
# SLACK_CLIENT_SECRET=your_slack_client_secret

# Google OAuth
# GOOGLE_OAUTH_CLIENT_ID=your_google_client_id
# GOOGLE_OAUTH_CLIENT_SECRET=your_google_client_secret
# GOOGLE_OAUTH_CALLBACK_URL=https://seu-dominio.com/omniauth/google_oauth2/callback

# ============================================
# 📊 APM & MONITORING (OPTIONAL)
# ============================================

# Sentry (Error tracking)
# SENTRY_DSN=your_sentry_dsn

# New Relic
# NEW_RELIC_LICENSE_KEY=your_license_key
# NEW_RELIC_APP_NAME=Chatwoot

# ============================================
# 🌍 LOCALIZATION (OPTIONAL)
# ============================================

# Default language (en, pt_BR, es, etc.)
# DEFAULT_LOCALE=pt_BR

# ============================================
# 🎨 BRANDING (OPTIONAL)
# ============================================

# Custom installation name
# INSTALLATION_NAME=Seu Nome da Empresa

# ============================================
# ⚡ PERFORMANCE (OPTIONAL)
# ============================================

# PostgreSQL query timeout
# POSTGRES_STATEMENT_TIMEOUT=14s

# Node options
# NODE_OPTIONS=--max-old-space-size=4096

# ============================================
# 🔗 WEBHOOKS & BACKGROUND JOBS (OPTIONAL)
# ============================================

# Use URL for background jobs
# USE_INBOX_AVATAR_FOR_BOT=true

# ============================================
# NOTAS IMPORTANTES
# ============================================
#
# 1. SECRET_KEY_BASE: NUNCA use o exemplo. Gere um único para produção.
# 2. DATABASE_URL: Pegue do PostgreSQL service do EasyPanel
# 3. REDIS_URL: Pegue do Redis service do EasyPanel
# 4. FRONTEND_URL: Configure com seu domínio real (com HTTPS)
# 5. FORCE_SSL: Sempre true em produção
# 6. Volumes persistentes: Monte /app/storage no EasyPanel
#
# ============================================
