From 2bbe944fe95abe3344660101acea46969b668545 Mon Sep 17 00:00:00 2001
From: Kanban Patch Bot <noreply@chatwoot.com>
Date: Sun, 8 Mar 2026 22:57:46 -0300
Subject: [PATCH] fix(kanban): add missing KANBAN_BOARD_ROUND_ROBIN_AGENTS
 Redis key constant

- Adds KANBAN_BOARD_ROUND_ROBIN_AGENTS constant to Redis::RedisKeys
- Fixes Internal Server Error when deleting Kanban boards
- Round robin service was referencing undefined constant
---
 lib/redis/redis_keys.rb | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/lib/redis/redis_keys.rb b/lib/redis/redis_keys.rb
index 8c9361ab5..28d47115e 100644
--- a/lib/redis/redis_keys.rb
+++ b/lib/redis/redis_keys.rb
@@ -3,6 +3,10 @@ module Redis::RedisKeys
   # Array storing the ordered ids for agent round robin assignment
   ROUND_ROBIN_AGENTS = 'ROUND_ROBIN_AGENTS:%<inbox_id>d'.freeze

+  ## Kanban Keys
+  # Array storing the ordered ids for agent round robin assignment in Kanban boards
+  KANBAN_BOARD_ROUND_ROBIN_AGENTS = 'KANBAN_BOARD_ROUND_ROBIN_AGENTS:%<board_id>d'.freeze
+
   ## Conversation keys
   # Detect whether to send an email reply to the conversation
   CONVERSATION_MAILER_KEY = 'CONVERSATION::%<conversation_id>d'.freeze
